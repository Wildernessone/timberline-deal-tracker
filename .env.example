# Per-Vercel-project env. Each portal is its own Vercel project; set NEXT_PUBLIC_PORTAL
# to one of: timberline | whitetail | waterfowl | turkey (turkey is ON HOLD — do not launch).
NEXT_PUBLIC_PORTAL=timberline

# Optional analytics / verification (client-exposed, safe to ship).
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GSC_TOKEN=

# Shared secret the scraper uses to trigger on-demand ISR revalidation
# (POST /api/revalidate?secret=...). Server-only — do NOT prefix with NEXT_PUBLIC_.
REVALIDATE_SECRET=
